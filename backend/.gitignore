# =============================================================
# BACKEND .gitignore
# =============================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
Venv/
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Environment secrets — NEVER commit API keys
.env
*.env

# Ingested / uploaded data files
data/

# Vector store local storage
vectorstore/
qdrant_storage/

# Jupyter Notebook
.ipynb_checkpoints/

# Logs
*.log

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
